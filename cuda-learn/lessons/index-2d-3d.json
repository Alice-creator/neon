  "html_content": "<style>\n.viz-wrap { font-family: monospace; padding: 20px 24px; background: #0f172a; color: #e2e8f0; }\n.viz-title { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: #64748b; margin-bottom: 14px; }\n.viz-row { display: flex; align-items: center; gap: 20px; margin-bottom: 28px; flex-wrap: wrap; }\n.mat-label { font-size: 11px; color: #94a3b8; margin-bottom: 6px; }\n.mat-grid { display: inline-grid; gap: 3px; }\n.mat-grid.r2c3 { grid-template-columns: repeat(3,1fr); }\n.mat-grid.r3c2 { grid-template-columns: repeat(2,1fr); }\n.cell { width: 48px; height: 38px; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 5px; font-size: 13px; font-weight: 700; cursor: default; transition: transform .15s; }\n.cell:hover { transform: scale(1.08); }\n.cell small { font-size: 9px; font-weight: 400; opacity: .7; margin-top: 1px; }\n.c0 { background:#1e3a5f; color:#60a5fa; }\n.c1 { background:#1e4a2f; color:#4ade80; }\n.c2 { background:#3b1f5c; color:#c084fc; }\n.c3 { background:#4a2200; color:#fb923c; }\n.c4 { background:#4a1a1a; color:#f87171; }\n.c5 { background:#1a3a40; color:#22d3ee; }\n.arr { font-size: 28px; color: #475569; align-self: center; padding-top: 20px; }\n.highlight { box-shadow: 0 0 0 2px #f59e0b; }\n.trace-box { background:#1e293b; border:1px solid #334155; border-radius:8px; padding:14px 18px; font-size:12px; line-height:1.9; }\n.trace-box .kw { color:#818cf8; }\n.trace-box .val { color:#34d399; font-weight:700; }\n.trace-box .eq  { color:#f59e0b; }\n.sec-sep { border:none; border-top:1px solid #1e293b; margin:10px 0 18px; }\n</style>\n<div class='viz-wrap'>\n  <div class='viz-title'>Matrix Transpose — 2x3 → 3x2 &nbsp;|&nbsp; thread highlight: row=0, col=2</div>\n  <div class='viz-row'>\n    <div>\n      <div class='mat-label'>IN &nbsp;[2 rows × 3 cols]</div>\n      <div class='mat-grid r2c3'>\n        <div class='cell c0'><span>1</span><small>[0,0]</small></div>\n        <div class='cell c1'><span>2</span><small>[0,1]</small></div>\n        <div class='cell c2 highlight'><span>3</span><small>[0,2]</small></div>\n        <div class='cell c3'><span>4</span><small>[1,0]</small></div>\n        <div class='cell c4'><span>5</span><small>[1,1]</small></div>\n        <div class='cell c5'><span>6</span><small>[1,2]</small></div>\n      </div>\n    </div>\n    <div class='arr'>→</div>\n    <div>\n      <div class='mat-label'>OUT [3 rows × 2 cols]</div>\n      <div class='mat-grid r3c2'>\n        <div class='cell c0'><span>1</span><small>[0,0]</small></div>\n        <div class='cell c3'><span>4</span><small>[0,1]</small></div>\n        <div class='cell c1'><span>2</span><small>[1,0]</small></div>\n        <div class='cell c4'><span>5</span><small>[1,1]</small></div>\n        <div class='cell c2 highlight'><span>3</span><small>[2,0]</small></div>\n        <div class='cell c5'><span>6</span><small>[2,1]</small></div>\n      </div>\n    </div>\n    <div class='trace-box'>\n      <div><span class='kw'>thread</span>: <span class='val'>row=0, col=2</span></div>\n      <div><span class='kw'>in_flat</span> <span class='eq'>=</span> row*cols+col <span class='eq'>=</span> <span class='val'>0×3+2 = 2</span></div>\n      <hr class='sec-sep'>\n      <div><span class='kw'>new_row</span>  = col     = <span class='val'>2</span></div>\n      <div><span class='kw'>new_col</span>  = row     = <span class='val'>0</span></div>\n      <div><span class='kw'>new_cols</span> = rows    = <span class='val'>2</span></div>\n      <hr class='sec-sep'>\n      <div><span class='kw'>out_flat</span> <span class='eq'>=</span> new_row*new_cols+new_col</div>\n      <div style='padding-left:60px'><span class='eq'>=</span> <span class='val'>2×2+0 = 4</span></div>\n      <div>in[<span class='val'>2</span>] → out[<span class='val'>4</span>] ✓</div>\n    </div>\n  </div>\n</div>"
}
